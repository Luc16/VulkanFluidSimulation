#version 450
#extension GL_GOOGLE_include_directive : require
#extension GL_EXT_debug_printf : enable

#include "common.glsl"

layout (binding = 0) uniform ParameterUBO {
    ComputeUBO ubo;
};

layout(std430, binding = 1) buffer TypesSSBO {
    uint types[ ];
};

layout(std430, binding = 2) buffer VelXSSBO {
    float velX[ ];
};

layout(std430, binding = 3) buffer VelYSSBO {
    float velY[ ];
};

layout(std430, binding = 4) buffer VelZSSBO {
    float velZ[ ];
};

layout (local_size_x = 256, local_size_y = 1, local_size_z = 1) in;

void main() {
    uint i = gl_GlobalInvocationID.x;

    ivec3 dim = ubo.dim;

    // y boudary
    if (i < dim.x*dim.z) {
        types[i] = SOLID;
        types[i + dim.x * dim.z * (dim.y - 1)] = SOLID;

        if (velY[i] < 0) velY[i] = 0.0f;
        if (velY[i + dim.x * dim.z] < 0) velY[i + dim.x * dim.z] = 0.0f;
        if (velY[i + dim.x * dim.z * (dim.y - 1)] > 0) velY[i + dim.x * dim.z * (dim.y - 1)] = 0.0f;
        if (velY[i + dim.x * dim.z * (dim.y - 2)] > 0) velY[i + dim.x * dim.z * (dim.y - 2)] = 0.0f;

        velX[i] = 0.0f;
        velX[i + dim.x * dim.z] = 0.0f;
        velX[i + dim.x * dim.z * (dim.y - 1)] = 0.0f;
        velX[i + dim.x * dim.z * (dim.y - 2)] = 0.0f;

        velZ[i] = 0.0f;
        velZ[i + dim.x * dim.z] = 0.0f;
        velZ[i + dim.x * dim.z * (dim.y - 1)] = 0.0f;
        velZ[i + dim.x * dim.z * (dim.y - 2)] = 0.0f;
    }

    // x boundary
    if (i < dim.y * dim.z) {
        types[i*dim.x] = SOLID;
        types[i*dim.x + dim.x - 1] = SOLID;

        if (velX[i*dim.x] < 0) velX[i*dim.x] = 0.0f;
        if (velX[i*dim.x + 1] < 0) velX[i*dim.x + 1] = 0.0f;
        if (velX[i*dim.x + dim.x - 1] > 0) velX[i*dim.x + dim.x - 1] = 0.0f;
        if (velX[i*dim.x + dim.x - 2] > 0) velX[i*dim.x + dim.x - 2] = 0.0f;

        velY[i*dim.x] = 0.0f;
        velY[i*dim.x + 1] = 0.0f;
        velY[i*dim.x + dim.x - 1] = 0.0f;
        velY[i*dim.x + dim.x - 2] = 0.0f;

        velZ[i*dim.x] = 0.0f;
        velZ[i*dim.x + 1] = 0.0f;
        velZ[i*dim.x + dim.x - 1] = 0.0f;
        velZ[i*dim.x + dim.x - 2] = 0.0f;
    }

    // z boundary
    if (i < dim.x * dim.y) {
        uint lower = (i / dim.x) * dim.x * dim.z + i % dim.x;
        uint upper = lower + dim.x * (dim.z - 1);
        types[lower] = SOLID;
        types[upper] = SOLID;

        if (velZ[lower] < 0) velZ[lower] = 0.0f;
        if (velZ[lower + dim.x] < 0) velZ[lower + dim.x] = 0.0f;
        if (velZ[upper] > 0) velZ[upper] = 0.0f;
        if (velZ[upper - dim.x] > 0) velZ[upper - dim.x] = 0.0f;

        velX[lower] = 0.0f;
        velX[lower + dim.x] = 0.0f;
        velX[upper] = 0.0f;
        velX[upper - dim.x] = 0.0f;

        velY[lower] = 0.0f;
        velY[lower + dim.x] = 0.0f;
        velY[upper] = 0.0f;
        velY[upper - dim.x] = 0.0f;
    }

}